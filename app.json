{
  "expo": {
    "name": "BunNotes",
    "slug": "bunnotes",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.eendi.bunnotes",
      "permissions": [
        "RECORD_AUDIO",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": ["DEFAULT", "BROWSABLE"],
          "data": [
            { "scheme": "bunnotes" }
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.eendi.bunnotes",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "BunNotes needs microphone access to record voice notes for transcription.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "BunNotes needs microphone access to record voice notes."
        }
      ],
      "./plugins/withRecordWidget"
    ],
    "extra": {
      "eas": {
        "projectId": "bunnotes"
      }
    }
  }
}
